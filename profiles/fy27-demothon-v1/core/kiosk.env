# Kiosk service configuration
# Broker connection — uses Solace MESS Python SDK (SMF/TCP), separate from SAM's WebSocket URL.
BROKER_URL=tcp://192.168.88.188:55555
BROKER_VPN=ai168
BROKER_USERNAME=user01
BROKER_PASSWORD=password

# Kiosk HTTP settings
KIOSK_PORT=9888
KIOSK_HOST_URL=http://192.168.88.188:9888

# Internal container paths (matched to volume mounts in compose.yaml)
KIOSK_ITINERARY_DB=/data/db/itinerary.db
KIOSK_FLIGHTS_JSON=/data/mock/flights.json
KIOSK_FRONTEND_DIST=/data/frontend-dist
KIOSK_BRAND_DIR=/data/brand
