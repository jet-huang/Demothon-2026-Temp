# Docker Compose layer variables (Layer 1)
# Used by compose.yml and s3.compose.yml for container orchestration.
# NOT consumed by SAM runtime or deployed agents.

# --- SAM Image Configuration ---
SAM_MAIN_TAG=1.143.0
SAM_DEPLOYER_TAG=1.8.2
SAM_MAIN_OFFICIAL_IMAGE=cr.jbetalabs.com/solace/scr/official/solace-agent-mesh-enterprise
SAM_MAIN_IMAGE=cr.jbetalabs.com/solace/scr/twsolace/solace-agent-mesh-enterprise
SAM_DEPLOYER_OFFICIAL_IMAGE=cr.jbetalabs.com/solace/scr/official/sam-agent-deployer
SAM_DEPLOYER_IMAGE=cr.jbetalabs.com/solace/scr/twsolace/sam-agent-deployer

# --- Container Engine ---
CONTAINER_ENGINE=docker
CONTAINER_NETWORK=sam-local-network

# --- S3 Infrastructure (SeaweedFS) ---
S3_IMAGE=chrislusf/seaweedfs
S3_TAG=4.01
S3_CLIENT_IMAGE=chrislusf/seaweedfs
S3_CLIENT_TAG=4.01
S3_INIT_SCRIPT=./scripts/init-seaweedfs.sh
S3_SAM_USER=sam
S3_API_PORT=8333
S3_SEAWEEDFS_MASTER_PORT=9333
S3_SEAWEEDFS_FILER_PORT=18888

# --- System ---
TZ=Asia/Taipei
