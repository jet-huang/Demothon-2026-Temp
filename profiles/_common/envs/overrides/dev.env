# Development environment overrides
# Complete dev configuration: addresses, credentials, auth, namespace.

# --- Solace Broker Connection ---
SOLACE_BROKER_VPN=test01
SOLACE_BROKER_USERNAME=user01
SOLACE_BROKER_PASSWORD=password
SOLACE_DEV_MODE=false
# SAM runtime (inside Docker network, can reach host via host.docker.internal)
SOLACE_BROKER_URL=ws://host.docker.internal:8008
# Agent containers (inside DinD, must use actual IP)
AGENT_BROKER_URL=ws://192.168.88.188:8008

# --- S3 / Artifact Storage ---
S3_BUCKET_NAME=sam-artifacts
S3_ACCESS_KEY_ID=sam-is-my-id
S3_SECRET_ACCESS_KEY=di-ym-si-mas
AWS_ACCESS_KEY_ID=sam-is-my-id
AWS_SECRET_ACCESS_KEY=di-ym-si-mas
# SAM runtime
S3_ENDPOINT_URL=http://host.docker.internal:8333
# Agent containers (inside DinD)
AGENT_S3_ENDPOINT_URL=http://192.168.88.188:8333

# --- Platform Service URL ---
PLATFORM_SERVICE_URL=http://dev88:8001

# --- Auth & Namespace ---
# Dev uses permissive auth (no restrictions)
SAM_AUTHORIZATION_CONFIG=/proj/configs/auth/insecure_permissive_auth_config.yaml
NAMESPACE=default_namespace
