# Production environment overrides
# Complete prod configuration: addresses, credentials, auth, namespace.
# Replace placeholder values with actual production settings.

# --- Solace Broker Connection ---
SOLACE_BROKER_VPN=PROD_VPN
SOLACE_BROKER_USERNAME=PROD_BROKER_USER
SOLACE_BROKER_PASSWORD=PROD_BROKER_PASSWORD
SOLACE_DEV_MODE=false
# SAM runtime
SOLACE_BROKER_URL=ws://PROD_BROKER_HOST:8008
# Agent containers
AGENT_BROKER_URL=ws://PROD_BROKER_HOST:8008

# --- S3 / Artifact Storage ---
S3_BUCKET_NAME=sam-artifacts
S3_ACCESS_KEY_ID=PROD_S3_ACCESS_KEY
S3_SECRET_ACCESS_KEY=PROD_S3_SECRET_KEY
AWS_ACCESS_KEY_ID=PROD_S3_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=PROD_S3_SECRET_KEY
# SAM runtime
S3_ENDPOINT_URL=http://PROD_S3_HOST:8333
# Agent containers
AGENT_S3_ENDPOINT_URL=http://PROD_S3_HOST:8333

# --- Platform Service URL ---
PLATFORM_SERVICE_URL=http://PROD_PLATFORM_HOST:8001

# --- Auth & Namespace ---
# Prod uses restrictive auth (deny all by default, configure explicit grants)
SAM_AUTHORIZATION_CONFIG=/proj/configs/auth/deny_all_auth_config.yaml
NAMESPACE=prod_namespace

# --- Session ---
# SESSION_SECRET_KEY=GENERATE_STRONG_KEY_HERE
