# LLM Profile: air-gapped
# Uses private / on-premise LLM endpoints with no internet dependency.
# Suitable for production or restricted network environments.
#
# Replace the placeholder values below with your actual private LLM endpoints.

# --- LLM Service ---
LLM_SERVICE_ENDPOINT=http://PRIVATE_LLM_HOST:8080/v1
LLM_SERVICE_API_KEY=YOUR_PRIVATE_API_KEY
LLM_SERVICE_PLANNING_MODEL_NAME=YOUR_PLANNING_MODEL
LLM_SERVICE_GENERAL_MODEL_NAME=YOUR_GENERAL_MODEL

# --- Image Service ---
IMAGE_SERVICE_ENDPOINT=http://PRIVATE_LLM_HOST:8080/v1
IMAGE_SERVICE_API_KEY=YOUR_PRIVATE_API_KEY
IMAGE_MODEL_NAME=YOUR_IMAGE_MODEL
