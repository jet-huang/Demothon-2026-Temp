# LLM Profile: public
# Uses public cloud LLM endpoints (LiteLLM proxy to AWS Bedrock).
# Suitable for development and demo environments with internet access.

# --- LLM Service ---
LLM_SERVICE_ENDPOINT=https://lite-llm.ymmv.net/
LLM_SERVICE_API_KEY=your_litellm_api_key_here
LLM_SERVICE_PLANNING_MODEL_NAME=openai/vertex-claude-4-5-sonnet-5-sonnet
LLM_SERVICE_GENERAL_MODEL_NAME=openai/vertex-claude-4-5-sonnet

# --- Image Service ---
IMAGE_SERVICE_ENDPOINT=https://lite-llm.ymmv.net/
IMAGE_SERVICE_API_KEY=your_litellm_api_key_here
IMAGE_MODEL_NAME=vertex-claude-4-5-sonnet
