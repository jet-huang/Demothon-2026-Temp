# SAM Runtime layer variables (Layer 2)
# Used inside the SAM main container (curr-proj/.env).
# NOT consumed by Docker Compose or deployed agents directly.

# --- Gateway / API Binding ---
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_HTTPS_PORT=8443
PLATFORM_API_HOST=0.0.0.0
PLATFORM_API_PORT=8001
REST_API_HOST=0.0.0.0
REST_API_PORT=8080

# --- SSL (empty = disabled) ---
SSL_KEYFILE=
SSL_CERTFILE=
SSL_KEYFILE_PASSWORD=

# --- Session ---
SESSION_SECRET_KEY=please_change_me_in

# --- Frontend ---
DEMO_TARGET=Solace SAM
FRONTEND_WELCOME_MESSAGE="歡迎使用 Solace Agent Mesh 服務 ^_^"
FRONTEND_BOT_NAME="我是個 BOT"
# FRONTEND_COLLECT_FEEDBACK=false

# --- Embed / Logging ---
ENABLE_EMBED_RESOLUTION=True
LOGGING_CONFIG_PATH=configs/logging_config.yaml
CONNECTOR_SPEC_BUCKET_NAME=sam-artifacts

# --- Agent Databases (SQLite for dev, override for prod) ---
A_CUSTOMERS_DB_TYPE=sqlite
A_CUSTOMERS_DB_NAME="db/customers.sqlite"
A_APP_INTERACTIONS_DB_TYPE=sqlite
A_APP_INTERACTIONS_DB_NAME="db/app_interactions.sqlite"
A_CLAIMS_DB_TYPE=sqlite
A_CLAIMS_DB_NAME="db/claims.sqlite"
A_CUSTOMER_SERVICE_AGENTS_DB_TYPE=sqlite
A_CUSTOMER_SERVICE_AGENTS_DB_NAME="db/customer_service_agents.sqlite"
A_MARKETING_INTERACTIONS_DB_TYPE=sqlite
A_MARKETING_INTERACTIONS_DB_NAME="db/marketing_interactions.sqlite"
A_PREMIUM_PAYMENTS_DB_TYPE=sqlite
A_PREMIUM_PAYMENTS_DB_NAME="db/premium_payments.sqlite"
A_PHONE_INTERACTIONS_DB_TYPE=sqlite
A_PHONE_INTERACTIONS_DB_NAME="db/phone_interactions.sqlite"
